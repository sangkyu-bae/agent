# OpenAI API Key (필수)
OPENAI_API_KEY=sk-your-api-key-here

# Qdrant 설정
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents

# LLM Wiki (LLM-WIKI-001) — 정제 위키 전용 벡터 컬렉션
WIKI_COLLECTION_NAME=wiki_knowledge

# OpenAI 모델 설정
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# Parser 설정
PARSER_TYPE=pymupdf

# Chunking 설정
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=100

# RAG 검색 설정
# 벡터 코사인 유사도 컷오프 전역 기본값 (0.0 = 비활성, 0.0~1.0).
# 에이전트별 tool_config.score_threshold가 없으면 이 값이 적용된다.
RAG_VECTOR_SCORE_THRESHOLD=0.0

# Database (MySQL)
DATABASE_URL=mysql+asyncmy://user:password@localhost:3306/idt

# Application
DEBUG=false

# Anthropic API Key (엑셀 분석 에이전트용)
ANTHROPIC_API_KEY=

# LlamaParse API Key (AI 기반 PDF 파싱용, INGEST-001)
LLAMA_PARSE_API_KEY=

# Tavily API Key (웹 검색용)
TAVILY_API_KEY=

# Excel Analysis Agent (AGENT-002) 설정
ANALYSIS_MAX_RETRIES=3
ANALYSIS_RETRY_ON_HALLUCINATION=true
ANALYSIS_REQUIRE_WEB_SEARCH_ON_RETRY=true
ANALYSIS_MIN_CONFIDENCE_SCORE=0.7
ANALYSIS_MAX_HALLUCINATION_SCORE=0.3

# Agent Attachment (ws-agent-excel-attachment) — WS 엑셀 첨부 업로드
# 빈 값이면 {시스템 tmp}/agent_attachments 로 자동 해석
AGENT_ATTACHMENT_UPLOAD_DIR=
AGENT_ATTACHMENT_MAX_BYTES=10485760
AGENT_ATTACHMENT_TTL_SECONDS=3600

# Redis 설정 (REDIS-001)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# Elasticsearch 설정 (ES-001)
ES_HOST=localhost
ES_PORT=9200
ES_SCHEME=http
ES_USERNAME=
ES_PASSWORD=
ES_CA_CERTS=
ES_MAX_RETRIES=3
ES_RETRY_ON_TIMEOUT=true
ES_REQUEST_TIMEOUT=30
ES_INDEX=documents

# Ollama 설정 (OLLAMA-001 - 로컬 LLM, API 키 불필요)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_MAX_TOKENS=4096
OLLAMA_TEMPERATURE=0.7
OLLAMA_TIMEOUT=120

# 폐쇄망 self-host LLM (vLLM/OpenAI 호환, LLM-MODEL-REG-002)
# - 엔드포인트 주소는 모델 등록 시 base_url 로 지정한다 (DB 저장).
# - vLLM에 인증이 없으면 EMPTY 더미값, 있으면 실제 토큰을 넣는다.
QWEN_API_KEY=EMPTY

# LangSmith 설정 (선택)
LANGSMITH_TRACING=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=

# MCP Registry (naver-search-mcp-integration)
# MCP_SECRET_KEY: 등록 MCP 서버의 auth_config/server_config(시크릿)를 Fernet 대칭암호화하는 키.
# ⚠️ streamable_http(Smithery 등 api_key 필수) 서버를 등록하려면 이 키가 반드시 필요하다.
#    빈 값이면 streamable_http 등록/수정이 422로 거부된다(시크릿이 NULL로 버려지는 것을 방지).
#    SSE 등 시크릿 없는 서버만 쓸 경우에는 빈 값이어도 동작한다.
# 키 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MCP_SECRET_KEY=

# Agent Schedule (agent-schedule)
# SCHEDULER_TRIGGER_TOKEN: 외부 트리거(POST /api/v1/internal/schedules/trigger) 인증 토큰.
# 빈 값이면 트리거 비활성(503). 외부 cron/작업 스케줄러가 X-Scheduler-Token 헤더로 전달.
# 등록 예 (매 분): * * * * * curl -s -X POST http://localhost:8000/api/v1/internal/schedules/trigger -H "X-Scheduler-Token: <token>"
SCHEDULER_TRIGGER_TOKEN=

# PII Masking (pii-masking)
# PII_MASKING_ENABLED: 외부 LLM 경계의 가역 PII 마스킹 전역 on/off. false면 no-op.
# PII_MASKING_TYPES: 활성 PII 타입(쉼표 구분). 지원: rrn,phone,email,card,account
# PII_MASKING_OUTPUT_REDACT: 응답에서 vault에 없는 신규 PII를 [REDACTED_<TYPE>]로 처리할지.
PII_MASKING_ENABLED=true
PII_MASKING_TYPES=rrn,phone,email,card,account
PII_MASKING_OUTPUT_REDACT=true

# Agent Composer (nl-agent-composer)
# COMPOSER_MAX_CANDIDATES: POST /agents/compose LLM에 주입하는 후보 도구 상한.
# 초과분은 절단되고 경고 로그가 남는다.
COMPOSER_MAX_CANDIDATES=100

# CHART BUILDER
# CHART_MAX_COUNT: 한 응답에 포함할 최대 차트 개수 (기본 3). 0이면 차트 비활성.
CHART_MAX_COUNT=3

# Search Pipeline (search-node-query-pipeline)
# search 노드 쿼리 재작성/검증/압축용 경량 LLM. provider/model 빈 값이면 에이전트 LLM 재사용.
SEARCH_PIPELINE_PROVIDER=openai
SEARCH_PIPELINE_MODEL_NAME=gpt-4o-mini
# 검색결과 압축 발동 임계 길이(자). 이하면 원문 그대로 전달.
SEARCH_COMPRESS_THRESHOLD=4000

# AUTH (AUTH-001)
# JWT_SECRET_KEY: 충분히 긴 랜덤 문자열 사용 (python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Document Extractor (document-template-extractor)
# 문서추출기: 업로드 상한(MB)/슬롯 상한/재추천 상한, 원본 영구 보관 디렉토리.
DOCUMENT_EXTRACTOR_MAX_FILE_MB=20
DOCUMENT_EXTRACTOR_MAX_SLOTS=30
DOCUMENT_EXTRACTOR_MAX_REGEN=10
DOCUMENT_TEMPLATE_DIR=
# 기본 MCP 변환 도구 id ("mcp_{uuid}") — extract 요청에 미지정 시 폴백.
# MCP 레지스트리에 pdf/doc<->html 변환 서버 등록 후 해당 tool_id를 지정.
DOCUMENT_EXTRACTOR_PDF_TO_HTML_TOOL_ID=
DOCUMENT_EXTRACTOR_HTML_TO_DOC_TOOL_ID=
# 미리보기 전용 layout 변환 (doc-extractor-preview-highlight).
# layout=PDF 미리보기 이원화 활성(기본), off=비활성(text HTML 폴백). dpi 72~300.
DOCUMENT_EXTRACTOR_PREVIEW_MODE=layout
DOCUMENT_EXTRACTOR_PREVIEW_DPI=120
