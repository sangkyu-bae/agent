# OpenAI API Key (필수)
OPENAI_API_KEY=sk-your-api-key-here

# Qdrant 설정
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents

# OpenAI 모델 설정
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# Parser 설정
PARSER_TYPE=pymupdf

# Chunking 설정
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=100

# Database (MySQL)
DATABASE_URL=mysql+asyncmy://user:password@localhost:3306/idt

# Application
DEBUG=false

# Anthropic API Key (엑셀 분석 에이전트용)
ANTHROPIC_API_KEY=

# LlamaParse API Key (AI 기반 PDF 파싱용, INGEST-001)
LLAMA_PARSE_API_KEY=

# Tavily API Key (웹 검색용)
TAVILY_API_KEY=

# Excel Analysis Agent (AGENT-002) 설정
ANALYSIS_MAX_RETRIES=3
ANALYSIS_RETRY_ON_HALLUCINATION=true
ANALYSIS_REQUIRE_WEB_SEARCH_ON_RETRY=true
ANALYSIS_MIN_CONFIDENCE_SCORE=0.7
ANALYSIS_MAX_HALLUCINATION_SCORE=0.3

# Redis 설정 (REDIS-001)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# Elasticsearch 설정 (ES-001)
ES_HOST=localhost
ES_PORT=9200
ES_SCHEME=http
ES_USERNAME=
ES_PASSWORD=
ES_CA_CERTS=
ES_MAX_RETRIES=3
ES_RETRY_ON_TIMEOUT=true
ES_REQUEST_TIMEOUT=30
ES_INDEX=documents

# Ollama 설정 (OLLAMA-001 - 로컬 LLM, API 키 불필요)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_MAX_TOKENS=4096
OLLAMA_TEMPERATURE=0.7
OLLAMA_TIMEOUT=120

# LangSmith 설정 (선택)
LANGSMITH_TRACING=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=

# AUTH (AUTH-001)
# JWT_SECRET_KEY: 충분히 긴 랜덤 문자열 사용 (python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
